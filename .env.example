# ANDS environment configuration example
# Copy this file to .env and replace placeholder values.

# LLM provider settings (used by optional LLM-based components)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6

# PostgreSQL connection string (required if history persistence is enabled)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# History lookup defaults
HISTORY_WINDOW_HOURS=24
MAX_HISTORY_RECORDS=20

# Kibana/Elasticsearch integration (leave KIBANA_HOST empty to use stub mode)
KIBANA_HOST=
KIBANA_INDEX=ands-alerts
KIBANA_USER=
KIBANA_PASS=
KIBANA_VERIFY_CERTS=0
