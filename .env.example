# ANDS environment configuration example
# Copy this file to .env and replace placeholder values.

# LLM provider settings (optional components)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6

# SIEM backend selection
# Recommended: elasticsearch (Kibana-backed SIEM history)
# Options: auto, elasticsearch, sqlite, postgresql, stub
SIEM_BACKEND=elasticsearch

# Kibana / Elasticsearch settings (used when SIEM_BACKEND=elasticsearch)
KIBANA_HOST=http://localhost:9200
KIBANA_INDEX=ands-alerts
KIBANA_USER=
KIBANA_PASS=
KIBANA_VERIFY_CERTS=0

# SIEM fusion behavior
USE_SIEM_HISTORY=1
SIEM_WINDOW_MINUTES=10
KIBANA_SAVE_ALL=1

# SQL SIEM persistence (used for sqlite/postgresql backends)
# If SIEM_DB_URL is empty and SIEM_BACKEND is auto/sqlite, SIEM_SQLITE_PATH is used.
SIEM_DB_URL=
SIEM_SQLITE_PATH=data/siem_history.db
SIEM_DB_TABLE=siem_alerts
SIEM_MAX_ALERTS=50

# PostgreSQL compatibility fallback (optional)
# Used when SIEM_BACKEND=postgresql and SIEM_DB_URL is not set.
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Legacy history lookup defaults
HISTORY_WINDOW_HOURS=24
MAX_HISTORY_RECORDS=20
